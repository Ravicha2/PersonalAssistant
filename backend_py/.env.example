# Backend
PORT=3000
DATA_DIR=./data
JWT_SECRET=change-me-in-production
BACKEND_API_KEY=

# LLM (optional; extension can send api_key per request)
ANTHROPIC_API_KEY=

# Google OAuth (for Connectors → Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
CALENDAR_TIMEZONE=Asia/Jakarta

# Optional: fallback MCP servers JSON (prefer saving in app via Connectors)
# MCP_SERVERS_JSON=[{"id":"time","command":"npx","args":["-y","@modelcontextprotocol/server-time"]}]
