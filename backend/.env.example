# --- Required for sign-in (JWT) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# --- Optional: API keys (extension can send its own) ---
# Backend API key for extension when not using sign-in
# BACKEND_API_KEY=your-secret-token

# Default LLM key if extension doesn't send one
# ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: Google (one OAuth = Calendar, then Gmail/Drive) ---
# Without these, GET /auth/google returns 503. Create OAuth 2.0 Desktop credentials at console.cloud.google.com, enable Calendar API.
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Calendar timezone for created events (IANA, e.g. Asia/Jakarta). User times like "23:55" are shown at that local time.
# CALENDAR_TIMEZONE=Asia/Jakarta

# --- Optional: Server ---
# PORT=3000
# DATA_DIR=./data
# ALLOWED_ORIGINS=*
