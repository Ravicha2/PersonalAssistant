# --- Required for sign-in (JWT) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# --- Optional: API keys (extension can send its own) ---
# Backend API key for extension when not using sign-in
# BACKEND_API_KEY=your-secret-token

# Default LLM key if extension doesn't send one
# ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: Google (Calendar & Docs) — choose one or both ---
# Built-in (recommended when app is online for multiple users): each user connects their own Google in Connectors.
# Create OAuth 2.0 Desktop app at console.cloud.google.com; enable Calendar API and Docs API. Redirect URI: http://localhost:3000/auth/google/callback (or your backend URL).
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Google Workspace MCP: only if you add that MCP in Connectors. Same or different OAuth app; backend injects into MCP process.
# GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=xxx

# Calendar timezone for events (IANA, e.g. Asia/Jakarta).
# CALENDAR_TIMEZONE=Asia/Jakarta

# --- Optional: External MCP servers (student tools: search, time, todos, etc.) ---
# Prefer saving per-user in the app (Connectors → Add MCP servers → Save to backend); stored in data/mcp-servers.json.
# Or set here as default/fallback. JSON array of { "id", "command", "args?", "env?" }.
# Example (Brave Search + Time — get Brave key at brave.com/search/api):
# MCP_SERVERS_JSON=[{"id":"brave","command":"npx","args":["-y","@modelcontextprotocol/server-brave-search"],"env":{"BRAVE_API_KEY":"your-key"}},{"id":"time","command":"npx","args":["-y","@modelcontextprotocol/server-time"]}]
# NotebookLM (Python: pip install notebooklm-mcp, then init + config path):
# MCP_SERVERS_JSON=[{"id":"notebooklm","command":"notebooklm-mcp","args":["--config","/path/to/notebooklm-config.json","server"]}]
# MCP_SERVERS_JSON=

# --- Optional: Server ---
# PORT=3000
# DATA_DIR=./data
# ALLOWED_ORIGINS=*
