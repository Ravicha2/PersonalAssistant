# Optional: Default Anthropic key if extension doesn't send one (users can set their own in extension)
# ANTHROPIC_API_KEY=sk-ant-...

# Required: Backend API key that the extension sends (e.g. generate a random string)
BACKEND_API_KEY=your-secret-token

# Optional: Port (default 3000)
PORT=3000

# Optional: Allowed WebSocket origins (comma-separated). Use chrome-extension:// for extension.
# Example: http://localhost:3000,chrome-extension://abcdefghijklmnop
ALLOWED_ORIGINS=*
